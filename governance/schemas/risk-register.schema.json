{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "risks": {
      "items": {
        "properties": {
          "decision": {
            "enum": [
              "accept",
              "avoid",
              "mitigate",
              "transfer"
            ]
          },
          "id": {
            "minLength": 1,
            "type": "string"
          },
          "owner": {
            "minLength": 1,
            "type": "string"
          },
          "severity": {
            "enum": [
              "low",
              "medium",
              "high",
              "critical"
            ]
          }
        },
        "required": [
          "id",
          "severity",
          "owner"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "version": {
      "type": "string"
    }
  },
  "required": [
    "version",
    "risks"
  ],
  "title": "Governance risk register",
  "type": "object"
}
