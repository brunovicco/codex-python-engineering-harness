{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/session_context.py\"",
            "timeout": 15,
            "statusMessage": "Loading safe repository context"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/validate_bash.py\"",
            "timeout": 15,
            "statusMessage": "Checking command safety"
          }
        ]
      },
      {
        "matcher": "^mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/guard_mcp.py\"",
            "timeout": 15,
            "statusMessage": "Checking MCP safety"
          }
        ]
      },
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/protect_sensitive_files.py\"",
            "timeout": 15,
            "statusMessage": "Protecting sensitive paths"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/scan_secrets.py\"",
            "timeout": 15,
            "statusMessage": "Scanning changed file"
          },
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/format_python.py\"",
            "timeout": 60,
            "statusMessage": "Formatting changed Python file"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/.codex/hooks/scan_worktree.py\"",
            "timeout": 30,
            "statusMessage": "Scanning changed files"
          }
        ]
      }
    ]
  }
}
