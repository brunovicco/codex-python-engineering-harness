APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
SERVICE_NAME={{PROJECT_NAME}}

# Optional vendor-neutral OpenTelemetry traces (see docs/LLM_OBSERVABILITY.md).
# Network-silent unless an endpoint is explicitly set. Requires `uv sync --extra observability`.
# OTEL_SDK_DISABLED=false
# OTEL_SERVICE_NAME={{PROJECT_NAME}}
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_RESOURCE_ATTRIBUTES=deployment.environment.name=development,service.version=0.1.0

# Optional Langfuse tracing (opt-in; see docs/LLM_OBSERVABILITY.md).
# Leave unset to keep tracing disabled. Requires `uv sync --extra tracing`.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_CAPTURE_CONTENT=false
